<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HERO -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/gradient_bg">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_margin="16dp"
                android:background="@drawable/circle_white_bg"
                android:src="@android:drawable/ic_menu_revert"
                android:scaleType="centerInside"
                android:padding="6dp"
                app:tint="@color/pink_primary" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Checkout"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/white" />

            </LinearLayout>

        </FrameLayout>

        <!-- CONTENT CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="-24dp"
            android:background="@drawable/card_top_rounded"
            android:paddingHorizontal="24dp"
            android:paddingTop="28dp"
            android:paddingBottom="40dp">

            <!-- Order summary -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order Summary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/orderSummaryText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="#555555"
                android:lineSpacingMultiplier="1.6" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#EEEEEE" />

            <!-- Total -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

                <TextView
                    android:id="@+id/paymentTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/pink_primary" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="20dp"
                android:background="#EEEEEE" />

            <!-- Shipping Address Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Shipping Address"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="14dp" />

            <EditText
                android:id="@+id/shippingAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:hint="Full Delivery Address"
                android:textColorHint="#AAAAAA"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:background="@drawable/field_bg"
                android:paddingHorizontal="18dp"
                android:paddingVertical="12dp"
                android:gravity="top"
                android:inputType="textPostalAddress"
                android:lines="2" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="20dp"
                android:background="#EEEEEE" />

            <!-- Payment method section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Method"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="14dp" />

            <RadioGroup
                android:id="@+id/paymentMethodGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <RadioButton
                    android:id="@+id/radioCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Credit Card"
                    android:textSize="14sp"
                    android:checked="true"
                    android:buttonTint="@color/pink_primary" />

                <RadioButton
                    android:id="@+id/radioCash"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cash on Delivery"
                    android:textSize="14sp"
                    android:buttonTint="@color/pink_primary" />
            </RadioGroup>

            <!-- Card details container -->
            <LinearLayout
                android:id="@+id/cardDetailsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Card number -->
                <EditText
                    android:id="@+id/cardNumber"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Card Number"
                    android:textColorHint="#AAAAAA"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:background="@drawable/field_bg"
                    android:paddingHorizontal="18dp"
                    android:inputType="number"
                    android:maxLength="16" />

                <!-- Expiry + CVV row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <EditText
                        android:id="@+id/cardExpiry"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="MM/YY"
                        android:textColorHint="#AAAAAA"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:background="@drawable/field_bg"
                        android:paddingHorizontal="18dp"
                        android:inputType="number"
                        android:maxLength="4" />

                    <EditText
                        android:id="@+id/cardCvv"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:hint="CVV"
                        android:textColorHint="#AAAAAA"
                        android:textColor="#1A1A1A"
                        android:textSize="14sp"
                        android:background="@drawable/field_bg"
                        android:paddingHorizontal="18dp"
                        android:inputType="numberPassword"
                        android:maxLength="3" />

                </LinearLayout>

                <!-- Cardholder name -->
                <EditText
                    android:id="@+id/cardName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="12dp"
                    android:hint="Cardholder Name"
                    android:textColorHint="#AAAAAA"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:background="@drawable/field_bg"
                    android:paddingHorizontal="18dp"
                    android:inputType="textPersonName" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="20dp"
                android:background="#EEEEEE" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Coupon Code"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/couponInput"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:hint="Enter coupon code"
                    android:textColorHint="#AAAAAA"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:background="@drawable/field_bg"
                    android:paddingHorizontal="18dp"
                    android:inputType="textCapCharacters" />

                <Button
                    android:id="@+id/applyCouponBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:text="Apply"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/pink_primary" />

            </LinearLayout>

            <TextView
                android:id="@+id/couponStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Place order -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#EEEEEE" />

            <Button
                android:id="@+id/placeOrderBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Place Order"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:backgroundTint="@color/pink_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="14dp"
                android:text="This is a demo — no real charge"
                android:textSize="12sp"
                android:textColor="#AAAAAA" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>