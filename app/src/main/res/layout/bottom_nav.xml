<?xml version="1.0" encoding="utf-8"?>
<!--
    bottom_nav.xml — included in Home, Favorites, Cart, Profile.
    Each screen highlights its own tab in Java by setting alpha.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="64dp"
    android:orientation="horizontal"
    android:background="#FFFFFF"
    android:elevation="8dp">

    <!-- Home tab -->
    <LinearLayout
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_home"
            android:contentDescription="Home"
            app:tint="@color/pink_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textSize="10sp"
            android:textColor="@color/pink_primary"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Favorites tab -->
    <LinearLayout
        android:id="@+id/navFavorites"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_favorites"
            android:contentDescription="Favorites"
            app:tint="@color/pink_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Favorites"
            android:textSize="10sp"
            android:textColor="@color/pink_primary"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Cart tab -->
    <LinearLayout
        android:id="@+id/navCart"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_cart"
            android:contentDescription="Cart"
            app:tint="@color/pink_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cart"
            android:textSize="10sp"
            android:textColor="@color/pink_primary"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Profile tab -->
    <LinearLayout
        android:id="@+id/navProfile"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_profile"
            android:contentDescription="Profile"
            app:tint="@color/pink_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:textSize="10sp"
            android:textColor="@color/pink_primary"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</LinearLayout>